---
import { cn } from "@/helpers/cn";
import { ArrowRight, type AstroComponent } from "@lucide/astro";
import { Icon } from "astro-icon/components";

type Color = "blue" | "green" | "red" | "yellow" | "purple" | "orange";
type Size = "medium" | "large";

interface Props {
  icon: AstroComponent;
  description: string;
  href: string;
  color?: Color;
  decorators?: string[];
  size?: Size;
}

const {
  icon: CardIcon,
  description,
  href,
  color = "blue",
  decorators = [],
  size = "medium",
} = Astro.props;

const bgColors = {
  blue: "bg-blue-500",
  green: "bg-green-500",
  red: "bg-red-500",
  yellow: "bg-yellow-500",
  purple: "bg-purple-500",
  orange: "bg-orange-500",
};

const hoverColors = {
  blue: "hover:text-blue-500",
  green: "hover:text-green-500",
  red: "hover:text-red-500",
  yellow: "hover:text-yellow-500",
  purple: "hover:text-purple-500",
  orange: "hover:text-orange-500",
};
---

<div
  class={cn(
    "bg-blue-500 rounded-lg p-4 pt-8 text-white flex flex-col items-start relative overflow-hidden",
    bgColors[color],
    size === "medium" ? "max-w-75" : "max-w-86",
  )}
>
  <Icon
    name={decorators[0] || "react"}
    size={70}
    class="absolute -top-4 -right-4 animate-spin animate-duration-20000 opacity-35"
  />

  <CardIcon size={36} />
  <p class="text-2xl leading-[1.15] font-medium text-white my-6 uppercase">
    {description}
  </p>
  <a
    href={href}
    class={cn(
      "border border-white hover:bg-white hover:text-blue-500 transition-colors rounded-md p-1 self-end",
      hoverColors[color],
    )}
  >
    <ArrowRight />
  </a>
  <Icon
    name={decorators[1] || "react"}
    size={35}
    class="absolute left-2 bottom-2 opacity-35"
  />
</div>
