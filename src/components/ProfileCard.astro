---
import { Icon } from "astro-icon/components";
import ButtonLink from "./ButtonLink.astro";
import CardIconsDecoration from "./CardIconsDecoration.astro";
---

<div
  role="complementary"
  class="w-86 h-max bg-white rounded-2xl sticky top-0 left-0 p-10 pb-8 flex flex-col items-center overflow-hidden"
>
  <picture>
    <img
      src="/images/avatar.avif"
      alt="Foto de perfil"
      class="w-60 h-70 object-cover rounded-2xl"
    />
  </picture>

  <article class="text-center mt-5">
    <h1 class="text-3xl font-bold text-black">Alex Rizo</h1>
    <p class="text-lg font-medium leading-tight mt-25">
      Desarrollador Full-Stack enfocado en soluciones innovadoras y escalables.
    </p>
  </article>
  <footer class="flex gap-6 mt-8">
    <ButtonLink href="https://github.com/AlexRizo">
      <Icon name="github" size={22} class="text-orange-500" />
    </ButtonLink>
    <ButtonLink href="https://linkedin.com/in/dev-alex-rizo">
      <Icon name="linkedin" size={22} class="text-orange-500" />
    </ButtonLink>
    <ButtonLink href="#">
      <Icon name="instagram" size={22} class="text-orange-500" />
    </ButtonLink>
  </footer>
  <CardIconsDecoration />
</div>
